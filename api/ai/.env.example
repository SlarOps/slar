# ============================================================
# AI Agent Environment Variables
# ============================================================

# Control Plane Registration (REQUIRED for multi-agent setup)
# Agent will self-register with Control Plane on startup
CONTROL_PLANE_URL=http://localhost:8080
AI_PROJECT_ID=your-project-id-here  # REQUIRED: Project this agent serves
AI_ORG_ID=your-org-id-here          # REQUIRED: Organization ID
AI_HOST=localhost                    # Agent host (use "ai" in Docker)
AI_PORT=8002                         # Agent WebSocket port

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Supabase (for conversation storage)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Database (for audit logs, cost tracking)
DATABASE_URL=postgresql://user:password@localhost:5432/database

# API Integration
API_BASE_URL=http://localhost:8080  # Go API URL for AuthzClient

# CORS Configuration
AI_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:3001

# Rate Limiting
AI_RATE_LIMIT=60  # Requests per minute

# Optional: Vault for credentials
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your-vault-token
