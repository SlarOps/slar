# ======================
# SLAR Docker Compose Environment Variables
# ======================
# Copy this file to .env and configure your values

# ======================
# OIDC Authentication (Standard OpenID Connect)
# ======================
# Configure any OIDC-compliant identity provider (Zitadel, Keycloak, Auth0, Okta, Google, etc.)
# All endpoints are auto-discovered via /.well-known/openid-configuration
OIDC_ISSUER=http://localhost:8080
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=  # Optional - only needed for confidential clients (leave empty for PKCE)

# ======================
# NextAuth.js
# ======================
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-key-min-32-chars

# ======================
# API URLs (for browser/client-side)
# ======================
# These must be URLs that the browser can access (not internal Docker hostnames)
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:8081
NEXT_PUBLIC_AI_API_URL=http://localhost:8002
NEXT_PUBLIC_AI_WS_URL=ws://localhost:8002/ws/chat

# For production with domain:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_AI_API_URL=https://ai.yourdomain.com
# NEXT_PUBLIC_AI_WS_URL=wss://ai.yourdomain.com/ws/chat

# ======================
# Database
# ======================
DATABASE_URL=postgresql://postgres:postgres@db:5432/slar?sslmode=disable

# ======================
# Optional Services
# ======================
# Slack Integration
# SLACK_BOT_TOKEN=xoxb-xxx
# SLACK_APP_TOKEN=xapp-xxx
# SLACK_SIGNING_SECRET=xxx

# Firebase Cloud Messaging
# FCM_CREDENTIALS_PATH=/app/firebase-credentials.json
