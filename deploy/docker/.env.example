# =============================================================================
# SLAR Environment Configuration
# Copy this file to .env and configure your settings
# =============================================================================

# -----------------------------------------------------------------------------
# OIDC Authentication — use any OIDC-compliant provider
# -----------------------------------------------------------------------------
# SLAR does not bundle an IDP. Point it at any standard OIDC provider:
#
#   Cloudflare Access:  OIDC_ISSUER=https://<team>.cloudflareaccess.com
#   Google:             OIDC_ISSUER=https://accounts.google.com
#   Zitadel:            OIDC_ISSUER=https://your-instance.zitadel.cloud
#   Auth0:              OIDC_ISSUER=https://your-tenant.auth0.com
#   Okta:               OIDC_ISSUER=https://your-org.okta.com
#   Keycloak:           OIDC_ISSUER=https://keycloak.example.com/realms/your-realm
#
# Redirect URI to register with your provider:
#   http://localhost:8000/api/auth/callback/oidc
#
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# NextAuth.js — required
# -----------------------------------------------------------------------------
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# API URLs (through Kong API Gateway on port 8000)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_AI_API_URL=http://localhost:8000/ai
NEXT_PUBLIC_AI_WS_URL=ws://localhost:8000/ws/chat
